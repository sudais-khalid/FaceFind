# App
APP_ENV=development
SECRET_KEY=your-random-32-byte-hex-string-here
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database
POSTGRES_PASSWORD=change-me-to-a-real-password
DATABASE_URL=postgresql+asyncpg://facefind:change-me-to-a-real-password@localhost:5432/facefind_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_API_KEY=your-google-api-key-for-public-drive-folders

# Base URL used to build signed file-access links returned to the client.
# Must match wherever the backend is actually reachable from the browser.
PUBLIC_BASE_URL=http://localhost:8000

# Encryption
MASTER_ENCRYPTION_KEY=your-random-32-byte-hex-string-here

# FAISS
FAISS_INDEX_DIR=./faiss_indexes

# CV Models
ARCFACE_MODEL_PATH=./models/arcface_r100.onnx
YUNET_MODEL_PATH=./models/face_detection_yunet_2023mar.onnx
RETINAFACE_MODEL_PATH=./models/retinaface_r50.onnx
ANTISPOOFING_MODEL_PATH=./models/anti_spoof_v1.onnx
FACE_DETECTION_THRESHOLD=0.6
INDEX_IMAGES_FROM_THUMBNAILS=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate Limiting
RATE_LIMIT_SCAN=5/minute
RATE_LIMIT_SEARCH=10/minute
RATE_LIMIT_LOGIN=10/15minute
